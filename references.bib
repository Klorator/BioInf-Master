@article{smogorzewskaControlHumanTelomere2000,
  title = {Control of {{Human Telomere Length}} by {{TRF1}} and {{TRF2}}},
  author = {Smogorzewska, Agata and {van Steensel}, Bas and Bianchi, Alessandro and Oelmann, Stefan and Schaefer, Matthias R. and Schnapp, Gisela and {de Lange}, Titia},
  year = 2000,
  month = mar,
  journal = {Molecular and Cellular Biology},
  volume = {20},
  number = {5},
  pages = {1659--1668},
  publisher = {Taylor \& Francis},
  issn = {null},
  doi = {10.1128/MCB.20.5.1659-1668.2000},
  urldate = {2026-02-27},
  abstract = {Telomere length in human cells is controlled by a homeostasis mechanism that involves telomerase and the negative regulator of telomere length, TRF1 (TTAGGG repeat binding factor 1). Here we report that TRF2, a TRF1-related protein previously implicated in protection of chromosome ends, is a second negative regulator of telomere length. Overexpression of TRF2 results in the progressive shortening of telomere length, similar to the phenotype observed with TRF1. However, while induction of TRF1 could be maintained over more than 300 population doublings and resulted in stable, short telomeres, the expression of exogenous TRF2 was extinguished and the telomeres eventually regained their original length. Consistent with their role in measuring telomere length, indirect immunofluorescence indicated that both TRF1 and TRF2 bind to duplex telomeric DNA in vivo and are more abundant on telomeres with long TTAGGG repeat tracts. Neither TRF1 nor TRF2 affected the expression level of telomerase. Furthermore, the presence of TRF1 or TRF2 on a short linear telomerase substrate did not inhibit the enzymatic activity of telomerase in vitro. These findings are consistent with the recently proposed t loop model of telomere length homeostasis in which telomerase-dependent telomere elongation is blocked by sequestration of the 3{$\prime$} telomere terminus in TRF1- and TRF2-induced telomeric loops.},
  pmid = {10669743},
  file = {C:\Users\Rasmus\Zotero\storage\AVHIPGMY\Smogorzewska et al. - 2000 - Control of Human Telomere Length by TRF1 and TRF2.pdf}
}


@article{stanselTloopAssemblyVitro2001,
  title = {T-loop Assembly in Vitro Involves Binding of {{TRF2}} near the 3{$\prime$} Telomeric Overhang},
  author = {Stansel, Rachel M. and {de Lange}, Titia and Griffith, Jack D.},
  year = 2001,
  month = oct,
  journal = {The EMBO Journal},
  volume = {20},
  number = {19},
  pages = {5532--5540},
  issn = {1460-2075},
  doi = {10.1093/emboj/20.19.5532},
  urldate = {2026-02-27},
  abstract = {Mammalian telomeres contain a duplex TTAGGG-repeat tract terminating in a 3{$\prime$} single-stranded overhang. TRF2 protein has been implicated in remodeling telomeres into duplex lariats, termed t-loops, in vitro and t-loops have been isolated from cells in vivo. To examine the features of the telomeric DNA essential for TRF2-promoted looping, model templates containing a 500 bp double-stranded TTAGGG tract and ending in different single-stranded overhangs were constructed. As assayed by electron microscopy, looped molecules containing most of the telomeric tract are observed with TRF2 at the loop junction. A TTAGGG-3{$\prime$} overhang of at least six nucleotides is required for loop formation. Termini with 5{$\prime$} overhangs, blunt ends or 3{$\prime$} termini with non-telomeric sequences at the junction are deficient in loop formation. Addition of non-telomeric sequences to the distal portion of a 3{$\prime$} overhang beginning with TTAGGG repeats only modestly diminishes looping. TRF2 preferentially localizes to the junction between the duplex repeats and the single-stranded overhang. Based on these findings we suggest a model for the mechanism by which TRF2 remodels telomeres into t-loops.},
  langid = {english},
  keywords = {electron microscopy,t-loop,telomere,TRF2},
  file = {C:\Users\Rasmus\Zotero\storage\7U7DTQEN\Stansel et al. - 2001 - T‐loop assembly in vitro involves binding of TRF2 near the 3′ telomeric overhang.pdf}
}


